{
  "name": "antigravity",
  "productName": "Antigravity",
  "version": "2.2.1",
  "description": "Antigravity - Agentic Desktop Application",
  "homepage": "https://antigravity.google",
  "author": {
    "name": "Google",
    "email": "antigravity-support@google.com"
  },
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "doctor": "node ag-doctor/bin/ag-doctor.js doctor",
    "doctor:check": "node ag-doctor/bin/ag-doctor.js check",
    "doctor:repair": "node ag-doctor/bin/ag-doctor.js repair --yes",
    "doctor:models": "node ag-doctor/bin/ag-doctor.js models list",
    "doctor:logs": "node ag-doctor/bin/ag-doctor.js logs -f -n 100",
    "patch:version": "node scripts/patch-version.js",
    "patch:2.2": "node scripts/patch_2_2_1.js",
    "patch:2.3": "node scripts/patch_2_3.js",
    "repack:win": "powershell -ExecutionPolicy Bypass -File scripts/repack/repack.ps1",
    "repack:mac": "bash scripts/deploy/deploy.sh",
    "repack:linux": "bash scripts/deploy/deploy_linux.sh",
    "mitm:start": "powershell -ExecutionPolicy Bypass -File scripts/mitm/start_mitm_443.ps1",
    "mitm:restart": "cmd /c scripts\\\\mitm\\\\restart-mitm.bat",
    "repatch": "cmd /c repatch.bat",
    "start:mitm": "cmd /c \"Start Antigravity MITM.bat\""
  },
  "dependencies": {
    "chrome-devtools-mcp": "^0.23.0",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "shell-env": "^4.0.3"
  },
  "devDependencies": {
    "@electron/asar": "^4.2.0",
    "vitest": "^4.1.10"
  }
}
