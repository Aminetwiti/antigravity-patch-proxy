{
  "name": "ag-doctor-ui",
  "version": "2.0.0",
  "description": "Premium Electron UI for the ag-doctor CLI",
  "main": "dist/main.js",
  "scripts": {
    "build": "node scripts/copy-assets.js && tsc -p tsconfig.json",
    "build:cli": "cd ../ag-doctor && npm install && npm run build",
    "prebuild": "node scripts/copy-assets.js && tsc -p tsconfig.json",
    "prepack": "npm run build && cd ../ag-doctor && npm install && npm run build && npm prune --omit=dev",
    "watch": "tsc -p tsconfig.json --watch",
    "start": "npm run build && electron .",
    "dev": "tsc -p tsconfig.json --watch & electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:portable": "npm run build && electron-builder --win portable",
    "dist:dir": "npm run build && electron-builder --dir",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "antigravity",
    "doctor",
    "electron",
    "cli",
    "diagnostic"
  ],
  "author": "Antigravity",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  },
  "build": {
    "appId": "dev.antigravity.doctor-ui",
    "productName": "ag-doctor",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "resources/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../ag-doctor/bin",
        "to": "ag-doctor/bin"
      },
      {
        "from": "../ag-doctor/dist",
        "to": "ag-doctor/dist"
      },
      {
        "from": "../ag-doctor/node_modules",
        "to": "ag-doctor/node_modules"
      },
      {
        "from": "../ag-doctor/package.json",
        "to": "ag-doctor/package.json"
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "ag-doctor-${version}-portable.${ext}"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
